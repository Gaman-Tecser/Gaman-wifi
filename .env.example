# Base de datos (PostgreSQL en servidor FreeRADIUS)
DATABASE_URL=postgresql://radius:PASSWORD@192.168.38.3:5432/radius

# Flask
SECRET_KEY=cambiar-por-clave-segura-aleatoria
FLASK_ENV=production

# Fernet key para encriptar passwords (generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=cambiar-por-fernet-key

# SSH al servidor FreeRADIUS (para restart)
RADIUS_SSH_HOST=192.168.38.3
RADIUS_SSH_USER=tecser
RADIUS_SSH_PASSWORD=cambiar

# Google OAuth (Portal Cautivo)
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
PORTAL_SESSION_HOURS=24
